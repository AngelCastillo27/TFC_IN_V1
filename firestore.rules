rules_version = '2';

// ============================================================
// Tsinghe Cocina Fusión - Reglas de seguridad Firestore
// Roles: "admin" | "comensal"
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Funcion auxiliar: comprueba si el usuario logueado es admin ──────
    function isAdmin() {
      return request.auth != null &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // ── Funcion auxiliar: comprueba si el usuario esta logueado ──────────
    function isLoggedIn() {
      return request.auth != null;
    }

    // ── Funcion auxiliar: comprueba si el uid del doc es el usuario actual
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // ════════════════════════════════════════════════════════════════════
    // USERS
    // Crear: solo el propio usuario al registrarse
    // Leer:  el propio usuario o un admin
    // Editar: el propio usuario o un admin
    // Borrar: solo admin
    // ════════════════════════════════════════════════════════════════════
    match /users/{uid} {
      allow create: if isOwner(uid);
      allow read:   if isOwner(uid) || isAdmin();
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ════════════════════════════════════════════════════════════════════
    // MENUS
    // Leer: publico (cualquiera, sin login)
    // Escribir: solo admin
    // ════════════════════════════════════════════════════════════════════
    match /menus/{menuId} {
      allow read:   if true;
      allow create,
            update,
            delete: if isAdmin();
    }

    // ════════════════════════════════════════════════════════════════════
    // OFFERS
    // Leer: publico
    // Escribir: solo admin
    // ════════════════════════════════════════════════════════════════════
    match /offers/{offerId} {
      allow read:   if true;
      allow create,
            update,
            delete: if isAdmin();
    }

    // ════════════════════════════════════════════════════════════════════
    // TABLES
    // Leer: cualquier usuario logueado (para ver disponibilidad)
    // Escribir: solo admin
    // ════════════════════════════════════════════════════════════════════
    match /tables/{tableId} {
      allow read:   if isLoggedIn();
      allow create,
            update,
            delete: if isAdmin();
    }

    // ════════════════════════════════════════════════════════════════════
    // RESERVATIONS
    // Leer: el propietario de la reserva o un admin
    // Crear: cualquier usuario logueado (solo con su propio userId)
    // Editar: el propietario o admin
    // Borrar: el propietario o admin
    // ════════════════════════════════════════════════════════════════════
    match /reservations/{reservationId} {
      allow read:   if isLoggedIn() &&
                       (resource.data.userId == request.auth.uid || isAdmin());

      allow create: if isLoggedIn() &&
                       request.resource.data.userId == request.auth.uid;

      allow update: if isLoggedIn() &&
                       (resource.data.userId == request.auth.uid || isAdmin());

      allow delete: if isLoggedIn() &&
                       (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ════════════════════════════════════════════════════════════════════
    // Todo lo demas: denegado por defecto
    // ════════════════════════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
